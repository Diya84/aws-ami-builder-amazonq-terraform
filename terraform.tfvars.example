# AMI Builder Configuration Example
# Copy this file to terraform.tfvars and customize the values

# Basic Configuration
name = "my-custom-ami"                    # Unique name for your AMI (no spaces, use hyphens)
aws_region = "us-west-2"                  # AWS region where resources will be created

# Network Configuration
vpc_id = "vpc-xxxxxxxxxxxxxxxxx"          # Existing VPC ID where AMI will be built
subnet_ids = ["subnet-xxxxxxxxxxxxxxxxx"] # List of subnet IDs for building (must have internet access)

# Instance Configuration
instance_types = ["c5.large"]             # Instance types for building AMI

# AMI Configuration
source_ami_name = "Windows_Server-2019-English-Full-Base-*"  # Base AMI pattern (Windows example)
# source_ami_name = "amzn2-ami-hvm-*-x86_64-gp2"            # Base AMI pattern (Linux example)
ami_name = "My Custom AMI"                # Display name for the created AMI
ami_description = "Custom AMI with specific software and configurations"

# Component File Names (generated by Amazon Q)
build_file_name = "my-custom-ami-components.yaml"  # Build phase component file
test_file_name = "my-custom-ami-test.yaml"         # Test phase component file

# Version Configuration
recipe_version = "1.0.0"                  # Image recipe version
build_version = "1.0.0"                   # Build component version
test_version = "1.0.0"                    # Test component version

# Distribution Configuration
target_account_ids = ["123456789012"]     # AWS account IDs to share AMI with
ami_regions = ["us-west-2"]               # Regions to distribute AMI to

# S3 Access Logging Configuration
enable_access_logging = true              # Enable S3 access logging
log_retention_days = 90                   # Days to retain access logs

# S3 Lifecycle Management Configuration
components_retention_days = 30            # Days to retain component files
scripts_retention_days = 90               # Days to retain script files

# Tags
tags = {
  created-by         = "Amazon-Q-AMI-Builder"
  dataclassification = "internal"         # Data classification level
  owner              = "MyTeam"           # Team or individual owner
  environment        = "dev"              # Environment (dev/staging/prod)
  project            = "ami-builder"      # Project name
  ami-type           = "my-custom-ami"    # AMI type identifier
}